# Öffentliche Supabase-Konfiguration für das Frontend (Vite).
# Kopiere diese Datei nach `.env.local` und trage die Werte deines Supabase-Projekts ein.
# Beide Werte sind öffentlich (kein Secret) — der anon-Key ist für den Browser gedacht.
# Zu finden im Supabase-Dashboard unter: Project Settings > API.

VITE_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-key

# Optional: Basis-Pfad, falls die App unter einem Unterpfad läuft (GitHub-Projekt-Seiten).
# Lokal nicht nötig. Der Deploy-Workflow setzt ihn automatisch auf /<repo>/.
# VITE_BASE_PATH=/caribbean-sovereign/
